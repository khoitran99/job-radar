{
  "name": "@jobradar/db",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prisma": "prisma",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "5.20.0"
  },
  "devDependencies": {
    "@types/node": "20.16.10",
    "prisma": "5.20.0",
    "typescript": "5.5.4"
  }
}
