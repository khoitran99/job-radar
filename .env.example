# Copy to .env and adjust as needed. .env is gitignored.

NODE_ENV=development

# --- API ---
API_PORT=3000
API_HOST=0.0.0.0

# --- Workers (health probe ports only; no public routes) ---
WORKER_HEALTH_PORT=3001
SCHEDULER_HEALTH_PORT=3002

# --- Web (Vite) ---
VITE_API_URL=http://localhost:3000

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jobradar
POSTGRES_PASSWORD=jobradar
POSTGRES_DB=jobradar
DATABASE_URL=postgresql://jobradar:jobradar@localhost:5432/jobradar?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- RabbitMQ ---
RABBITMQ_URL=amqp://jobradar:jobradar@localhost:5672
RABBITMQ_MANAGEMENT_URL=http://localhost:15672

# --- MongoDB ---
MONGO_URL=mongodb://jobradar:jobradar@localhost:27017/jobradar?authSource=admin

# --- Auth (Phase 1) ---
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=7d

# --- LLM (Phase 4) ---
ANTHROPIC_API_KEY=

# --- Email (Phase 6) ---
RESEND_API_KEY=
EMAIL_FROM=jobradar@example.com
